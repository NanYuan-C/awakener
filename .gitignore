# =============================================================================
# Awakener - Git Ignore Rules
# =============================================================================

# -- Secrets & Environment ----------------------------------------------------
.env
config.yaml

# -- Runtime-generated prompt files (created from templates on first run) ------
prompts/persona.md
prompts/rules.md
agents/activator/persona.md
agents/activator/rules.md

# -- Runtime Data (generated by agent) ----------------------------------------
data/
!data/.gitkeep

# -- Python --------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
*.egg-info/

# -- Logs ----------------------------------------------------------------------
*.log
*.jsonl

# -- OS Files ------------------------------------------------------------------
.DS_Store
Thumbs.db

# -- IDE -----------------------------------------------------------------------
.vscode/
.idea/
.cursor/
*.swp
*.swo
